# ResQDocs — example configuration.
# Copy to .env.local (gitignored) and adjust for your environment.
# This file must contain ONLY neutral placeholders — no real secrets,
# private domains, internal IPs, or personal data.

# --- Public project info (landing page / app) ------------------------------
PUBLIC_APP_NAME="ResQDocs"
PUBLIC_APP_URL="https://example.org"
PUBLIC_CONTACT_EMAIL="maintainer@example.org"

# --- Pico bridge (local HTTP endpoint / access point) ----------------------
# The bridge is reached over local HTTP. Prefer the mDNS name; an IP is only a
# fallback. These are neutral defaults; deployers may change them.
PICO_DEFAULT_HOST="http://pico.local"
PICO_API_BASE_PATH="/"

# --- Logging ---------------------------------------------------------------
# Logs must never contain patient or other sensitive data.
LOG_LEVEL="info"
