            "default": "wach, orientiert",
            "heading": { "prefix": "", "suffix": ": ", "fill": "", "width": 0, "fillMode": "inclusive" }
          },
          {
            "type": "field",
            "id": "anamnese",
            "title": "Anamnese",
            "showTitle": true,
            "multiline": true,
            "heading": { "prefix": "", "suffix": ":", "fill": "", "width": 0, "fillMode": "inclusive" }
          }
        ]
      }
    ]
  }
}
