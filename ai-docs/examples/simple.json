        "children": [
          {
            "type": "field",
            "id": "alter",
            "title": "Alter",
            "showTitle": true,
            "heading": { "prefix": "", "suffix": ": ", "fill": "", "width": 0, "fillMode": "inclusive" }
          },
          {
            "type": "field",
            "id": "geschlecht",
            "title": "Geschlecht",
            "showTitle": true,
            "options": ["männlich", "weiblich", "divers"],
            "heading": { "prefix": "", "suffix": ": ", "fill": "", "width": 0, "fillMode": "inclusive" }
          }
        ]
      },
      {
        "type": "container",
        "id": "befund",
        "title": "Befund",
        "showTitle": true,
        "blankLineBefore": true,
        "heading": { "prefix": "", "suffix": "", "fill": "", "width": 0, "fillMode": "inclusive" },
        "children": [
          {
            "type": "field",
            "id": "bewusstsein",
            "title": "Bewusstsein",
