# --- Secrets / environment -------------------------------------------------
.env
.env.*
!.env.example

# Keys & certificates (never commit real ones)
*.pem
*.key
*.crt
*.p12
*.pfx
# Mobile signing material (Android keystores, Apple provisioning/keys)
*.jks
*.keystore
keystore.properties
*.p8
*.mobileprovision

# App Store Connect export (Metadaten/Screenshots, kann Demo-Account-Passwoerter/Tester-Mails enthalten)
/asc-export/
*.mobileprovision
*.cer
*.p8

# KI-Doku: Manifest traegt Commit/Zeitstempel (bei jedem Build neu) -> nicht committen (sonst CI-Gate-Churn)
/ai-docs/generated/manifest.json

# Private / local working files
secrets/
private/
.local/
.cache/

# --- Dependencies & build output -------------------------------------------
node_modules/
dist/
build/
coverage/

# Firmware build output (compile artifacts)
firmware/bridge/build/
# Note: firmware/bridge/dist/*.uf2 are intentionally tracked as prebuilt
# flashing artifacts (a deliberate project exception, documented in the
# firmware README). General dist/ output elsewhere stays ignored.

# Capacitor native projects: SIND versioniert (Capacitor-Standardpraxis, #25) -
# sie tragen echte Konfiguration (Info.plist-Berechtigungen, ATS, Signing).
# Build-/Pod-Artefakte filtert das jeweilige ios|android/.gitignore.

# --- OS ---------------------------------------------------------------------
.DS_Store
Thumbs.db

# Core-Dumps
core

# Lokale Zusatzmuster fuer scripts/security-check.mjs (nie versionieren)
.security-patterns.local.json

# github/licensed cache (ephemer im CI; NICHT committen)
.licenses/

# Lokale Screenshot-Zips + fastlane-Artefakte (nie committen)
screen_*.zip
apps/pico-pwa/ios/App/fastlane/report.xml
apps/pico-pwa/ios/App/fastlane/README.md
