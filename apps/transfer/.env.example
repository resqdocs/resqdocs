# Beispielkonfiguration des Transfer-Dienstes. Echte Werte NICHT committen (.env ist gitignored).
# Port, auf dem der Node-Dienst lauscht (hinter dem externen Reverse Proxy).
PORT=8086
# Pfad zur SQLite-Datei (im Container das gemountete Volume).
TRANSFER_DB=/data/transfer.db
# In-App-Rate-Limit als Fallback abschalten, wenn der externe Proxy limitiert: RATE_LIMIT=off
RATE_LIMIT=on
# Kapazitaets-Cap: max. Anzahl gleichzeitig gespeicherter Blobs (Schutz vor unbegrenztem Disk-Wachstum).
# Bei Erreichen wird zuerst Abgelaufenes weggeraeumt, sonst 507. Grob: maxBlobs * 512 KB DB-Obergrenze.
TRANSFER_MAX_BLOBS=20000
# Reverse-Proxy-Socket-Adresse: NUR von diesem Peer wird X-Forwarded-For als echte Client-IP geglaubt
# (spoofsicher). Damit greift das In-App-Per-IP-Rate-Limit hinter dem Proxy wirklich pro Client statt global.
# Leer/ungesetzt = kein Proxy vertraut -> Rate-Limit pro Verbindungs-Peer (hinter Proxy = Proxy-IP = global).
TRUSTED_PROXY=
